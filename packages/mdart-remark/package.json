{
  "name": "mdart-remark",
  "version": "0.1.0",
  "description": "unified/remark plugin that renders mdart diagram fences as inline SVG",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build-esm.js",
    "dev": "tsc -p tsconfig.build.json --watch",
    "check": "tsc --noEmit"
  },
  "peerDependencies": {
    "mdart": ">=0.1.0",
    "unified": ">=11.0.0",
    "remark-parse": ">=11.0.0",
    "remark-rehype": ">=11.0.0",
    "rehype-stringify": ">=10.0.0",
    "unist-util-visit": ">=5.0.0"
  },
  "devDependencies": {
    "mdart": "*",
    "unified": "^11.0.5",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "rehype-stringify": "^10.0.1",
    "unist-util-visit": "^5.1.0",
    "typescript": "^5.9.3",
    "esbuild": "^0.25.0"
  }
}
