{
  "name": "mdart",
  "version": "0.1.0",
  "description": "MdArt — markdown-native diagram DSL renderer",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./preview": {
      "development": "./src/tabListInteract.ts",
      "import": "./dist/tabListInteract.js",
      "types": "./dist/tabListInteract.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build-esm.js",
    "dev": "tsc -p tsconfig.build.json --watch",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.1.0"
  }
}
