{
  "name": "vscode-mdart",
  "displayName": "MdArt Diagrams",
  "description": "Renders mdart diagram fences inline in the VS Code Markdown Preview.",
  "version": "0.1.0",
  "publisher": "mdart",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "diagram",
    "mdart",
    "preview"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/mdart/vscode-mdart"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "markdown.previewScripts": [
      "./dist/preview.js"
    ]
  },
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "check": "tsc --noEmit",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "mdart": "*",
    "mdart-markdown-it": "*",
    "typescript": "^5.9.3"
  }
}
